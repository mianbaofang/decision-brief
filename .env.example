# 别纠结 Skill 版本 - 环境变量配置示例
#
# 使用方法：
#   1. 复制本文件为 .env（或直接设置系统环境变量）
#   2. 修改下面的值为你的真实 API Key
#   3. 启动后端：cd backend && python main.py
#
# 注意：.env 文件已在 .gitignore 中，不会提交到仓库。
# 也可以通过前端设置页（http://localhost:8000/）或 CLI
# （python scripts/choice_assistant.py --action config-api --save-to-db ...）
# 写入 SQLite，三层优先级：环境变量 > SQLite > ~/.choice/config.json

# ─── LLM 配置（OpenAI 兼容协议）─────────────────────────────
# 必填三项：API Key + 模型名 + Base URL（缺一则走 mock 降级）
CHOICE_LLM_API_KEY=sk-your-openai-compatible-key
CHOICE_LLM_MODEL=gpt-4o-mini
CHOICE_LLM_BASE_URL=https://api.openai.com/v1

# ─── 高德天气配置（nature 模式用）──────────────────────────
# 高德开放平台 Key：个人开发者每日 10 万次免费
# 申请路径：https://lbs.amap.com/dev/key/app
# 文档：https://lbs.amap.com/api/webservice/guide/api/weatherinfo
# 缺一则 nature 模式返回基于关键词的 mock 自然意象
CHOICE_WEATHER_KEY=your-amap-key
CHOICE_WEATHER_CITY=北京
